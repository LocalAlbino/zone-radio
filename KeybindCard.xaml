<UserControl x:Class="ZoneRadio.KeybindCard"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ZoneRadio"
             mc:Ignorable="d" 
             Foreground="{x:Null}">
    <Grid Margin="0,10,0,10">
        <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Vertical">
            <TextBlock Text="{Binding Title, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="Black" FontSize="16"/>
            <TextBlock Text="{Binding Description, RelativeSource={RelativeSource AncestorType=UserControl}}" Foreground="Black" Margin="0,6,0,0" />
        </StackPanel>
        <!-- ComboBox values initialized in code-behind -->
        <ComboBox VerticalAlignment="Center" HorizontalAlignment="Right" x:Name="KeybindSelection" Height="20" Width="150" Margin="20,10,0,10"/>
    </Grid>
</UserControl>
